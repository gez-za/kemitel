{
  "name": "cm.lao.kemitel.bbp.web",
  "type": "module",
  "private": true,
  "version": "0.0.0-SNAPSHOT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:staging": "vue-tsc --noEmit && vite build --mode staging",
    "build:ci": "vue-tsc --noEmit && vite build --mode ci",
    "build:dev": "vue-tsc --noEmit && vite build --mode development",
    "preview": "vite preview --port 5050",
    "test:unit": "TZ=Africa/Douala vitest --environment jsdom",
    "test:e2e": "npx playwright test --ui",
    "test:e2e:ci": "TZ=Africa/Douala npx playwright test",
    "typecheck": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "storybook": "start-storybook -p 6006 --no-open",
    "build-storybook": "storybook build",
    "storybook-no-cache": "start-storybook -p 6006 --no-open --no-manager-cache",
    "precommit": "lint-staged",
    "prepare": "cd .. && husky install cm.lao.kemitel.bbp.web/.husky",
    "stylelint": "stylelint '**/*.css'",
    "get-version": "node -p \"require('./package').version\"",
    "delete:reports": "rm tests-reports/e2e/playwright-junit-*.xml || true",
    "combine:reports": "jrm tests-reports/e2e/playwright-junit.xml \"tests-reports/e2e/playwright-junit-*.xml\"",
    "openapi-generate-gateway": "openapi-ts --file openapi/gateway.config.ts",
    "openapi-generate": "npm run openapi-generate-gateway"
  },
  "dependencies": {
    "@bprogress/core": "^1.3.4",
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/vue-table": "^8.21.3",
    "@tsconfig/node22": "^22.0.0",
    "@vee-validate/yup": "^4.15.0",
    "@vuepic/vue-datepicker": "^11.0.2",
    "dayjs": "^1.11.13",
    "firebase": "^12.14.0",
    "pinia": "~2.3.1",
    "reka-ui": "^2.3.1",
    "tailwindcss": "^4.3.0",
    "vee-validate": "^4.15.0",
    "vue": "~3.5.13",
    "vue-i18n": "~11.1.0",
    "vue-router": "~4.3.3",
    "vue3-snackbar": "^2.5.0",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@pinia/testing": "^0.1.7",
    "@playwright/test": "^1.50.0",
    "@storybook/addon-docs": "^9.0.10",
    "@storybook/addon-onboarding": "^9.0.10",
    "@storybook/vue3-vite": "^9.0.10",
    "@types/jsdom": "^21.1.7",
    "@vitejs/plugin-vue": "~5.2.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "~0.7.0",
    "autoprefixer": "~10.4.2",
    "daisyui": "^5.0.0-beta.8",
    "eslint": "~9.20.0",
    "eslint-plugin-storybook": "^9.0.10",
    "husky": "~9.1.7",
    "jsdom": "^24.1.0",
    "junit-report-merger": "^3.0.5",
    "lint-staged": "12.1.2",
    "mocha-junit-reporter": "^2.0.2",
    "playwright": "^1.53.2",
    "postcss-html": "~1.8.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "storybook": "^9.0.10",
    "typescript": "~5.7.3",
    "vite": "~6.1.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "~3.0.5",
    "vue-tsc": "~2.2.0"
  }
}
